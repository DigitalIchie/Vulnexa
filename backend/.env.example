NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000
FRONTEND_ORIGIN=http://localhost:5500,http://127.0.0.1:5500

DATABASE_URL="file:./dev.db"

JWT_ACCESS_SECRET=replace-with-strong-64-char-random-secret
JWT_REFRESH_SECRET=replace-with-different-strong-64-char-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Leave empty to allow scanning any domain, or specify comma-separated list (e.g., example.com,staging.example.com)
ALLOWED_SCAN_DOMAINS=
MAX_CRAWL_PAGES=25
OUTBOUND_PROXY_URL=
PLAYWRIGHT_BROWSERS_PATH=./.playwright-browsers

SSL_KEY_PATH=
SSL_CERT_PATH=
