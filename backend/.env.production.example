NODE_ENV=production
PORT=4000
APP_URL=https://api.vulnexa.com
FRONTEND_ORIGIN=https://vulnexa.com,https://www.vulnexa.com

# Use managed Postgres/MySQL in production.
DATABASE_URL=postgresql://user:password@host:5432/dbname

JWT_ACCESS_SECRET=replace-with-strong-64-char-random-secret
JWT_REFRESH_SECRET=replace-with-different-strong-64-char-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Leave empty to allow scanning any domain, or specify comma-separated list
ALLOWED_SCAN_DOMAINS=
MAX_CRAWL_PAGES=25
OUTBOUND_PROXY_URL=
PLAYWRIGHT_BROWSERS_PATH=./.playwright-browsers

SSL_KEY_PATH=
SSL_CERT_PATH=
